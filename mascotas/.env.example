# ===========================================================================
#  Variables de entorno de Patitas
#  Copia este archivo como  .env  y completa los valores.
#  El archivo .env NO se sube al repositorio (esta en .gitignore).
# ===========================================================================

# --- Base de datos (Supabase) ---
# Las encuentras en tu proyecto Supabase: Project Settings > API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_KEY=tu-clave-publica-aqui

# --- Marca (aparece en los mensajes de difusion) ---
NOMBRE_APP=Patitas
URL_PUBLICA=https://patitas.streamlit.app

# --- Scraping (opcional) ---
# URLs publicas a recolectar, separadas por coma. Sin login.
# Revisa el robots.txt y los terminos de cada sitio antes de incluirlo.
SCRAPER_URLS=
SCRAPER_DELAY=2.0
SCRAPER_TIMEOUT=10.0
OUTPUT_CSV=data/raw/anuncios.csv
